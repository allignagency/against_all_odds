{%- if section.blocks.size > 0 -%}
  <style>
    #shopify-section-{{ section.id }} {
      {%- if section.settings.stack_on_mobile -%}
        --logo-list-grid: auto / repeat({{ 2 | at_most: section.blocks.size }}, minmax(0, 550px));
      {%- else -%}
        --logo-list-grid: auto / auto-flow max-content;
      {%- endif -%}

      --logo-list-item-border-color: {{ section.settings.logo_item_border.rgb }};
      --logo-list-gap: {{section.settings.gap}}px;
    }
    .sec-{{ section.id }} .logo-list__item img {
        border-radius: {{section.settings.radius}}px;
    }

    .sec-{{ section.id }} .logo-list__item {
        padding: 0;
    }

    @media screen and (min-width: 700px) {
      #shopify-section-{{ section.id }} {
        --logo-list-grid: auto / repeat({{ 3 | at_most: section.blocks.size }}, minmax(0, 550px));
      }
    }

    @media screen and (min-width: 1000px) {
      #shopify-section-{{ section.id }} {
        --logo-list-grid: auto / repeat({{ section.settings.items_per_row | at_most: section.blocks.size }}, minmax(0, 650px));
      }
    }
    @media screen and (min-width: 700px) {
        .sec-{{ section.id }} .logo-list__item {
            padding: 0;
        }
    }
    @media screen and (max-width: 700px) {
        .sec-{{ section.id }} .scroll-area .constrained-image {
            max-width: 250px;
        }
    }

    /* Lookbook trigger button */
    .sec-{{ section.id }} .lookbook-trigger {
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      display: block;
      width: 100%;
      text-align: left;
      position: relative;
    }

    .sec-{{ section.id }} .lookbook-trigger:hover .lookbook-trigger__overlay {
      opacity: 1;
    }

    .sec-{{ section.id }} .lookbook-trigger__overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.3);
      opacity: 0;
      transition: opacity 0.25s ease;
      border-radius: {{ section.settings.radius }}px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 0.8125rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 600;
    }

    /* Lookbook modal */
    .lookbook-modal {
      border: none;
      border-radius: 12px;
      padding: 0;
      max-width: min(92vw, 960px);
      width: 100%;
      max-height: 88vh;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
    }

    .lookbook-modal::backdrop {
      background: rgba(0, 0, 0, 0.55);
    }

    .lookbook-modal__inner {
      display: flex;
      flex-direction: column;
      max-height: 88vh;
    }

    .lookbook-modal__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 1.75rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
      flex-shrink: 0;
    }

    .lookbook-modal__title {
      margin: 0;
      font-size: 1.125rem;
      font-weight: 600;
    }

    .lookbook-modal__close {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem 0.5rem;
      font-size: 1.25rem;
      line-height: 1;
      color: currentColor;
      opacity: 0.6;
    }

    .lookbook-modal__close:hover {
      opacity: 1;
    }

    .lookbook-modal__body {
      display: flex;
      flex-direction: row;
      overflow: hidden;
      flex: 1;
      min-height: 0;
    }

    .lookbook-modal__image {
      width: 50%;
      flex-shrink: 0;
      overflow: hidden;
    }

    .lookbook-modal__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .lookbook-modal__products {
      width: 50%;
      display: flex;
      flex-direction: column;
      gap: 0;
      overflow-y: auto;
      padding: 1.25rem 1.5rem;
      gap: 1rem;
    }

    /* Individual product row */
    .lookbook-product {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }

    .lookbook-product:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .lookbook-product__image {
      width: 80px;
      flex-shrink: 0;
      border-radius: 6px;
      overflow: hidden;
    }

    .lookbook-product__image img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      display: block;
    }

    .lookbook-product__info {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .lookbook-product__title {
      font-size: 0.875rem;
      font-weight: 600;
      text-decoration: none;
      color: currentColor;
      line-height: 1.3;
    }

    .lookbook-product__title:hover {
      text-decoration: underline;
    }

    .lookbook-product__prices {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .lookbook-product__price {
      font-size: 0.875rem;
    }

    .lookbook-product__price--sale {
      color: #c0392b;
    }

    .lookbook-product__price--compare {
      font-size: 0.8125rem;
      text-decoration: line-through;
      opacity: 0.5;
    }

    .lookbook-product__atc {
      margin-top: 0.25rem;
      display: inline-block;
      padding: 0.45rem 1rem;
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: #000;
      color: #fff;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      text-decoration: none;
      text-align: center;
      width: 100%;
    }

    .lookbook-product__atc:hover {
      background: #222;
    }

    @media screen and (max-width: 700px) {
      .lookbook-modal__body {
        flex-direction: column;
        overflow-y: auto;
      }

      .lookbook-modal__image {
        width: 100%;
        max-height: 40vh;
        flex-shrink: 0;
      }

      .lookbook-modal__products {
        width: 100%;
        overflow-y: unset;
      }
    }
  </style>

  {%- assign color_scheme_hash = section.settings.color_scheme.settings.background_gradient | default: section.settings.color_scheme.settings.background | md5 -%}

  <div class="sec-{{ section.id }} section-spacing color-scheme color-scheme--{{ section.settings.color_scheme.id }} color-scheme--bg-{{ color_scheme_hash }} {% if section.settings.separate_section_with_border %}bordered-section{% endif %}">
    <div class="container container--xl">
      <div class="section-stack">
        {%- render 'section-header', subheading: section.settings.subheading, heading: section.settings.title, content: section.settings.content, text_alignment: 'center' -%}

        <div class="logo-list {% if section.settings.stack_on_mobile == false %}scroll-area bleed sm:unbleed{% endif %}">
          {%- for block in section.blocks -%}
            {%- assign has_products = false -%}
            {%- for i in (1..6) -%}
              {%- assign product_key = 'product_' | append: i -%}
              {%- if block.settings[product_key] != blank -%}
                {%- assign has_products = true -%}
              {%- endif -%}
            {%- endfor -%}

            {%- capture block_content -%}
              {%- if block.settings.logo != blank -%}
                {%- capture sizes -%}{{ block.settings.logo_width }}px{%- endcapture -%}
                {%- capture widths -%}{{ block.settings.logo_width }}, {{ block.settings.logo_width | times: 2 | at_most: block.settings.logo.width }}{%- endcapture -%}
                {%- capture max_width -%}--image-max-width: {{ block.settings.logo_width }}px{%- endcapture -%}
                {{- block.settings.logo | image_url: width: block.settings.logo.width | image_tag: style: max_width, widths: widths, sizes: sizes, class: 'constrained-image' -}}
              {%- else -%}
                {{- 'image' | placeholder_svg_tag: 'image placeholder' -}}
              {%- endif -%}
            {%- endcapture -%}

            {%- if has_products -%}
              <button
                class="logo-list__item lookbook-trigger"
                data-lookbook-trigger="lookbook-modal-{{ block.id }}"
                style="{% render 'surface', background: section.settings.logo_item_background %}"
                {{ block.shopify_attributes }}
              >
                {{- block_content -}}
                <span class="lookbook-trigger__overlay">Shop the look</span>
              </button>
            {%- elsif block.settings.link != blank -%}
              <a class="logo-list__item" href="{{ block.settings.link }}" style="{% render 'surface', background: section.settings.logo_item_background %}" {{ block.shopify_attributes }}>
                {{- block_content -}}
              </a>
            {%- else -%}
              <div class="logo-list__item" {{ block.shopify_attributes }} style="{% render 'surface', background: section.settings.logo_item_background %}">
                {{- block_content -}}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Render a modal for each block that has products {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- assign has_products = false -%}
    {%- for i in (1..6) -%}
      {%- assign product_key = 'product_' | append: i -%}
      {%- if block.settings[product_key] != blank -%}
        {%- assign has_products = true -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_products -%}
      <dialog class="lookbook-modal" id="lookbook-modal-{{ block.id }}" aria-modal="true" aria-label="Shop the look">
        <div class="lookbook-modal__inner">
          <div class="lookbook-modal__header">
            <p class="lookbook-modal__title">Shop the look</p>
            <button class="lookbook-modal__close" aria-label="Close dialog">&#x2715;</button>
          </div>
          <div class="lookbook-modal__body">
            {%- if block.settings.logo != blank -%}
              <div class="lookbook-modal__image">
                {{- block.settings.logo | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400,600,800,1000,1200' -}}
              </div>
            {%- endif -%}

            <div class="lookbook-modal__products">
              {%- for i in (1..6) -%}
                {%- assign product_key = 'product_' | append: i -%}
                {%- assign modal_product = block.settings[product_key] -%}
                {%- if modal_product != blank -%}
                  {%- assign modal_variant = modal_product.selected_or_first_available_variant -%}
                  <div class="lookbook-product">
                    {%- if modal_product.featured_media != blank -%}
                      <a href="{{ modal_product.url }}" class="lookbook-product__image" tabindex="-1" aria-hidden="true">
                        {{- modal_product.featured_media | image_url: width: 200 | image_tag: loading: 'lazy', widths: '100,150,200' -}}
                      </a>
                    {%- endif -%}
                    <div class="lookbook-product__info">
                      <a href="{{ modal_product.url }}" class="lookbook-product__title">{{ modal_product.title }}</a>
                      <div class="lookbook-product__prices">
                        {%- if modal_variant.compare_at_price > modal_variant.price -%}
                          <span class="lookbook-product__price lookbook-product__price--sale">
                            {{- modal_variant.price | money -}}
                          </span>
                          <span class="lookbook-product__price lookbook-product__price--compare">
                            {{- modal_variant.compare_at_price | money -}}
                          </span>
                        {%- else -%}
                          <span class="lookbook-product__price">
                            {{- modal_variant.price | money -}}
                          </span>
                        {%- endif -%}
                      </div>
                      {%- if modal_product.available -%}
                        {%- if modal_product.variants.size == 1 and modal_product.selling_plan_groups.size == 0 -%}
                          <product-form>
                            {%- form 'product', modal_product -%}
                              <input type="hidden" name="on_success" value="force_open_drawer">
                              <input type="hidden" name="quantity" value="1">
                              <input type="hidden" name="id" value="{{ modal_variant.id }}">
                              <button type="submit" class="lookbook-product__atc">Add to cart</button>
                            {%- endform -%}
                          </product-form>
                        {%- else -%}
                          <a href="{{ modal_product.url }}" class="lookbook-product__atc">Select options</a>
                        {%- endif -%}
                      {%- else -%}
                        <span class="lookbook-product__atc" style="background:#999;cursor:default;">Sold out</span>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </dialog>
    {%- endif -%}
  {%- endfor -%}

  <script>
    (function () {
      document.querySelectorAll('[data-lookbook-trigger]').forEach(function (trigger) {
        trigger.addEventListener('click', function () {
          var modal = document.getElementById(trigger.dataset.lookbookTrigger);
          if (modal) modal.showModal();
        });
      });

      document.addEventListener('click', function (e) {
        if (e.target.classList.contains('lookbook-modal__close')) {
          e.target.closest('dialog').close();
        }
        // Close on backdrop click
        if (e.target.tagName === 'DIALOG') {
          e.target.close();
        }
      });
    })();
  </script>

{%- endif -%}

{% schema %}
{
  "name": "Custom LookBook",
  "class": "shopify-section--logo-list",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "t:global.section.separate_section_with_border",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "t:global.text.subheading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:global.text.heading",
      "default": "Custom lookbook"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:global.text.content"
    },
    {
      "type": "checkbox",
      "id": "stack_on_mobile",
      "label": "t:sections.logo_list.stack_on_mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "items_per_row",
      "min": 3,
      "max": 7,
      "label": "t:sections.logo_list.items_per_row_desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Gap b/w images",
      "default": 10
    },
    {
      "type": "range",
      "id": "radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Corner Radius",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 100,
          "max": 600,
          "unit": "px",
          "step": 10,
          "label": "Max Image width",
          "default": 550
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:global.text.link",
          "info": "Only used if no products are selected below."
        },
        {
          "type": "header",
          "content": "Products in this look"
        },
        {
          "type": "paragraph",
          "content": "Select up to 6 products to show in the popup when this image is clicked."
        },
        {
          "type": "product",
          "id": "product_1",
          "label": "Product 1"
        },
        {
          "type": "product",
          "id": "product_2",
          "label": "Product 2"
        },
        {
          "type": "product",
          "id": "product_3",
          "label": "Product 3"
        },
        {
          "type": "product",
          "id": "product_4",
          "label": "Product 4"
        },
        {
          "type": "product",
          "id": "product_5",
          "label": "Product 5"
        },
        {
          "type": "product",
          "id": "product_6",
          "label": "Product 6"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom LookBook",
      "category": "t:global.categories.media",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}

        { "value": "xs", "label": "t:global.sizes.x_small" },
        { "value": "sm", "label": "t:global.sizes.small" },
        { "value": "md", "label": "t:global.sizes.medium" },
        { "value": "lg", "label": "t:global.sizes.large" }
